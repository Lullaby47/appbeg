rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function role() {
      return signedIn() && userExists(request.auth.uid)
        ? userDoc(request.auth.uid).data.role
        : null;
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isCoadmin() {
      return role() == 'coadmin';
    }

    function isStaff() {
      return role() == 'staff';
    }

    function isCarer() {
      return role() == 'carer';
    }

    function isPlayer() {
      return role() == 'player';
    }

    function isScopedWorker() {
      return isCoadmin() || isStaff() || isCarer();
    }

    function callerCoadminUid() {
      let data = userDoc(request.auth.uid).data;
      return isCoadmin() ? request.auth.uid : (data.coadminUid != null ? data.coadminUid : data.createdBy);
    }

    function scopedToCaller(data) {
      return signedIn() && (
        isAdmin() ||
        data.coadminUid == callerCoadminUid() ||
        data.createdBy == callerCoadminUid()
      );
    }

    function maintenanceEnabledFor(coadminUid) {
      return coadminUid != null &&
        exists(/databases/$(database)/documents/coadminMaintenance/$(coadminUid)) &&
        get(/databases/$(database)/documents/coadminMaintenance/$(coadminUid)).data.maintenanceBreak.enabled == true;
    }

    function protectedUserFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'role',
        'uid',
        'email',
        'coadminUid',
        'createdBy',
        'createdAt',
        'coin',
        'cash',
        'cashBoxNpr',
        'permissions',
        'isAdmin',
        'isCoadmin',
        'isCarer'
      ]);
    }

    function adminCoadminUserBrowserUpdateAllowed() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'displayName',
        'name',
        'usernameDisplay',
        'photoURL',
        'avatarUrl',
        'phone',
        'notificationPreferences',
        'updatedAt',
        'lastSeenAt',
        'theme',
        'preferences',
        'paymentDetailPhotos',
        'paymentDetailPhotoUrls',
        'paymentQrUrl',
        'paymentQrPublicId',
        'paymentDetails'
      ]);
    }

    function playerCarerEscalationAlertCreateAllowed() {
      return isPlayer()
        && request.resource.data.playerUid == request.auth.uid
        && scopedToCaller(request.resource.data)
        && request.resource.data.escalationFrom == 'player'
        && request.resource.data.contextType == 'cashbox_inquiry'
        && request.resource.data.taskId == null
        && request.resource.data.createdByCarerUid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'coadminUid',
          'contextType',
          'escalationFrom',
          'taskId',
          'playerUid',
          'playerUsername',
          'gameName',
          'message',
          'createdByCarerUid',
          'createdByCarerUsername',
          'createdAt',
          'status'
        ])
        && (
          !request.resource.data.keys().hasAny(['status']) ||
          request.resource.data.status in ['open', 'pending']
        );
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin() || (isScopedWorker() && scopedToCaller(resource.data)));

      // Users may maintain only explicitly harmless own-profile fields.
      // Balance, role, scope, identity, and app-control fields must move
      // through trusted server/admin paths.
      allow update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'name',
          'usernameDisplay',
          'photoURL',
          'avatarUrl',
          'phone',
          'notificationPreferences',
          'updatedAt',
          'lastSeenAt',
          'theme',
          'preferences'
        ]);

      allow update: if signedIn()
        && request.auth.uid == uid
        && isCoadmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'paymentDetailPhotos',
          'paymentDetailPhotoUrls',
          'updatedAt'
        ]);

      allow update: if signedIn()
        && request.auth.uid == uid
        && isCarer()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'paymentQrUrl',
          'paymentQrPublicId',
          'paymentDetails',
          'updatedAt'
        ]);

      // Existing admin/coadmin screens still perform some scoped profile updates
      // directly. Keep those functional, but never allow direct role changes.
      allow update: if signedIn()
        && (isAdmin() || (isCoadmin() && scopedToCaller(resource.data)))
        && adminCoadminUserBrowserUpdateAllowed();

      allow create, delete: if false;
    }

    match /playerGameRequests/{requestId} {
      allow read: if signedIn() && (
        isAdmin() ||
        resource.data.playerUid == request.auth.uid ||
        (isScopedWorker() && scopedToCaller(resource.data))
      );
      allow create: if false;
      allow update: if signedIn() && (
        isAdmin() ||
        (isScopedWorker() && scopedToCaller(resource.data)) ||
        (
          isPlayer() &&
          resource.data.playerUid == request.auth.uid &&
          request.resource.data.playerUid == request.auth.uid &&
          resource.data.type == 'redeem' &&
          request.resource.data.type == 'redeem' &&
          resource.data.status == 'pending' &&
          request.resource.data.status == 'dismissed' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'completedAt',
            'ttlExpiresAt',
            'pokedAt',
            'pokeMessage'
          ]) &&
          request.resource.data.pokedAt == null &&
          request.resource.data.pokeMessage == null
        )
      );
      allow delete: if isAdmin() || (isScopedWorker() && scopedToCaller(resource.data));
    }

    match /carerTasks/{taskId} {
      allow read: if signedIn() && (isAdmin() || (isScopedWorker() && scopedToCaller(resource.data)));
      allow create: if signedIn() && (isAdmin() || (isScopedWorker() && scopedToCaller(request.resource.data)));
      allow update: if signedIn() && (
        isAdmin() ||
        (
          isScopedWorker() &&
          scopedToCaller(resource.data) &&
          scopedToCaller(request.resource.data) &&
          (
            isCoadmin() ||
            resource.data.assignedCarerUid == request.auth.uid ||
            resource.data.assignedHandlerUid == request.auth.uid ||
            resource.data.status == 'pending'
          )
        )
      );
      allow delete: if isAdmin() || (isCoadmin() && scopedToCaller(resource.data));
    }

    match /playerCashoutTasks/{taskId} {
      allow read: if signedIn() && (
        isAdmin() ||
        resource.data.playerUid == request.auth.uid ||
        (isScopedWorker() && scopedToCaller(resource.data))
      );
      allow create: if false;
      allow update: if signedIn() && (isAdmin() || (isScopedWorker() && scopedToCaller(resource.data)));
      allow delete: if isAdmin() || (isCoadmin() && scopedToCaller(resource.data));
    }

    match /financialEvents/{eventId} {
      allow read: if signedIn() && (isAdmin() || (isScopedWorker() && scopedToCaller(resource.data)) || resource.data.playerUid == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /gameLogins/{docId} {
      allow read, update, delete: if signedIn() && (isAdmin() || (isScopedWorker() && scopedToCaller(resource.data)));
      allow create: if signedIn() && (isAdmin() || (isScopedWorker() && scopedToCaller(request.resource.data)));
    }

    match /playerGameLogins/{docId} {
      allow read: if signedIn() && (
        isAdmin() ||
        resource.data.playerUid == request.auth.uid ||
        (isScopedWorker() && scopedToCaller(resource.data))
      );
      allow create, update: if signedIn() && (
        isAdmin() ||
        request.resource.data.playerUid == request.auth.uid ||
        (isScopedWorker() && scopedToCaller(request.resource.data)) ||
        (isScopedWorker() && scopedToCaller(resource.data))
      );
      allow delete: if isAdmin() || (isScopedWorker() && scopedToCaller(resource.data));
    }

    match /bonusEvents/{docId} {
      allow read: if signedIn() && (
        isAdmin() ||
        (isPlayer() && scopedToCaller(resource.data)) ||
        (isScopedWorker() && scopedToCaller(resource.data))
      );
      allow create: if signedIn() && (isAdmin() || (isScopedWorker() && scopedToCaller(request.resource.data)));
      allow update, delete: if signedIn() && (isAdmin() || (isScopedWorker() && scopedToCaller(resource.data)));
    }

    match /carerCashouts/{docId} {
      allow read: if signedIn() && (
        isAdmin() ||
        resource.data.carerUid == request.auth.uid ||
        (isScopedWorker() && scopedToCaller(resource.data))
      );
      allow create: if signedIn() && (
        isAdmin() ||
        request.resource.data.carerUid == request.auth.uid ||
        (isScopedWorker() && scopedToCaller(request.resource.data))
      );
      allow update: if signedIn() && (isAdmin() || (isScopedWorker() && scopedToCaller(resource.data)));
      allow delete: if false;
    }

    match /transferRequests/{docId} {
      allow read: if signedIn() && (
        isAdmin() ||
        resource.data.playerUid == request.auth.uid ||
        (isScopedWorker() && scopedToCaller(resource.data))
      );
      allow create: if false;
      allow update: if signedIn() && (isAdmin() || (isScopedWorker() && scopedToCaller(resource.data)));
      allow delete: if false;
    }

    match /shiftSessions/{docId} {
      allow read: if signedIn() && (isAdmin() || (isScopedWorker() && scopedToCaller(resource.data)) || resource.data.userUid == request.auth.uid);
      allow create: if signedIn() && request.resource.data.userUid == request.auth.uid;
      allow update: if signedIn() && (
        isAdmin() ||
        resource.data.userUid == request.auth.uid ||
        (isScopedWorker() && scopedToCaller(resource.data))
      );
      allow delete: if false;
    }

    match /coinLoadSessions/{docId} {
      allow read: if signedIn() && (
        isAdmin() ||
        resource.data.playerUid == request.auth.uid ||
        (isScopedWorker() && scopedToCaller(resource.data))
      );
      allow create: if signedIn() && (
        isAdmin() ||
        (
          isPlayer() &&
          request.resource.data.playerUid == request.auth.uid &&
          request.resource.data.keys().hasOnly([
            'playerUid',
            'coadminUid',
            'hashCode',
            'paymentPhotoUrl',
            'createdAt',
            'expiresAt'
          ]) &&
          !maintenanceEnabledFor(request.resource.data.coadminUid)
        ) ||
        (isScopedWorker() && scopedToCaller(request.resource.data))
      );
      allow update: if signedIn() && (
        isAdmin() ||
        (isScopedWorker() && scopedToCaller(resource.data))
      );
      allow delete: if false;
    }

    match /coadminMaintenance/{coadminUid} {
      allow read: if signedIn() && (
        isAdmin() ||
        coadminUid == callerCoadminUid()
      );
      allow create, update: if signedIn() && (
        isAdmin() ||
        (isCoadmin() && coadminUid == request.auth.uid)
      );
      allow delete: if isAdmin();
    }

    match /devUsageEstimates/{docId} {
      allow read: if isAdmin();
      allow create, update: if signedIn() && (isAdmin() || isCoadmin() || isStaff() || isCarer() || isPlayer());
      allow delete: if false;
    }

    match /presence/{docId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && docId == request.auth.uid;
      allow delete: if false;
    }

    match /userPresence/{uid} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['lastSeenAt']);
      allow delete: if false;
    }

    match /riskActions/{docId} {
      allow read: if signedIn() && (
        isAdmin() ||
        (isScopedWorker() && scopedToCaller(resource.data)) ||
        resource.data.playerUid == request.auth.uid
      );
      allow create: if signedIn() && (
        isAdmin() ||
        ((isCoadmin() || isStaff() || isCarer()) && scopedToCaller(request.resource.data))
      );
      allow update, delete: if false;
    }

    match /playerRiskSnapshots/{playerUid} {
      allow read: if signedIn() && (
        isAdmin() ||
        (isScopedWorker() && scopedToCaller(resource.data)) ||
        playerUid == request.auth.uid
      );
      allow create: if signedIn() && (
        isAdmin() ||
        ((isCoadmin() || isStaff() || isCarer()) && scopedToCaller(request.resource.data))
      );
      allow update: if signedIn() && (
        isAdmin() ||
        ((isCoadmin() || isStaff() || isCarer()) && (
          scopedToCaller(resource.data) ||
          scopedToCaller(request.resource.data)
        ))
      );
      allow delete: if false;
    }

    match /carerEscalationAlerts/{alertId} {
      allow read: if signedIn() && (
        isAdmin() ||
        (isScopedWorker() && scopedToCaller(resource.data)) ||
        resource.data.playerUid == request.auth.uid
      );
      allow create: if signedIn() && (
        isAdmin() ||
        (isScopedWorker() && scopedToCaller(request.resource.data)) ||
        playerCarerEscalationAlertCreateAllowed()
      );
      allow update: if signedIn() && (
        (
          isAdmin() ||
          ((isCoadmin() || isStaff() || isCarer()) && scopedToCaller(resource.data)) ||
          resource.data.playerUid == request.auth.uid
        ) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dismissedByUids']) &&
        request.auth.uid in request.resource.data.dismissedByUids &&
        (
          !resource.data.keys().hasAny(['dismissedByUids']) ||
          resource.data.dismissedByUids is list
        ) &&
        request.resource.data.dismissedByUids is list &&
        request.resource.data.dismissedByUids.hasAll(
          resource.data.keys().hasAny(['dismissedByUids']) ? resource.data.dismissedByUids : []
        ) &&
        request.resource.data.dismissedByUids.toSet().difference(
          (resource.data.keys().hasAny(['dismissedByUids']) ? resource.data.dismissedByUids : []).toSet()
        ).hasOnly([request.auth.uid])
      );
      allow delete: if isAdmin() || ((isCoadmin() || isStaff() || isCarer()) && scopedToCaller(resource.data));
    }

    match /playerGameRedeemLimitResets/{docId} {
      allow read: if signedIn() && (
        isAdmin() ||
        (isScopedWorker() && scopedToCaller(resource.data)) ||
        resource.data.playerUid == request.auth.uid
      );
      allow create: if signedIn() && (
        isAdmin() ||
        ((isCoadmin() || isStaff() || isCarer()) && scopedToCaller(request.resource.data))
      );
      allow update: if signedIn() && (
        isAdmin() ||
        ((isCoadmin() || isStaff() || isCarer()) && (
          scopedToCaller(resource.data) ||
          scopedToCaller(request.resource.data)
        ))
      );
      allow delete: if false;
    }

    match /playerFriendLinks/{docId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn()
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants;
      allow update: if signedIn()
        && resource.data.participants is list
        && request.resource.data.participants is list
        && request.auth.uid in resource.data.participants
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants == resource.data.participants;
      allow delete: if false;
    }

    match /carerCreationRequests/{requestId} {
      allow read: if signedIn() && (
        isAdmin() ||
        resource.data.coadminUid == callerCoadminUid()
      );
      allow create, update, delete: if false;
    }

    function hasParticipant(data) {
      return data.participants is list && request.auth.uid in data.participants;
    }

    function conversationParticipant(conversationId) {
      return exists(/databases/$(database)/documents/conversations/$(conversationId)) &&
        hasParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)).data);
    }

    function playerConversationParticipant(conversationId) {
      return exists(/databases/$(database)/documents/playerConversations/$(conversationId)) &&
        hasParticipant(get(/databases/$(database)/documents/playerConversations/$(conversationId)).data);
    }

    function groupConversationParticipant(conversationId) {
      return conversationId == 'global' ||
        (
          exists(/databases/$(database)/documents/playerGroupConversations/$(conversationId)) &&
          hasParticipant(get(/databases/$(database)/documents/playerGroupConversations/$(conversationId)).data)
        );
    }

    function directMessageCreateAllowed(conversationId) {
      let parent = get(/databases/$(database)/documents/conversations/$(conversationId)).data;
      return conversationParticipant(conversationId)
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.receiverUid in parent.participants
        && request.resource.data.keys().hasOnly([
          'type',
          'text',
          'imageUrl',
          'imagePublicId',
          'senderUid',
          'receiverUid',
          'createdAt',
          'ttlExpiresAt'
        ]);
    }

    function playerMessageCreateAllowed(conversationId) {
      let parent = get(/databases/$(database)/documents/playerConversations/$(conversationId)).data;
      return playerConversationParticipant(conversationId)
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.receiverUid in parent.participants
        && request.resource.data.keys().hasOnly([
          'senderUid',
          'receiverUid',
          'text',
          'imageUrl',
          'imagePublicId',
          'type',
          'replyToMessageId',
          'replyToText',
          'searchTokens',
          'deliveredTo',
          'seenBy',
          'deletedFor',
          'createdAt',
          'ttlExpiresAt'
        ]);
    }

    function playerMessageUpdateAllowed(conversationId) {
      return playerConversationParticipant(conversationId)
        && request.resource.data.senderUid == resource.data.senderUid
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'deliveredTo',
            'seenBy',
            'deletedFor'
          ]) ||
          (
            resource.data.senderUid == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'text',
              'imageUrl',
              'imagePublicId',
              'deletedForEveryone',
              'searchTokens'
            ])
          )
        );
    }

    function groupMessageCreateAllowed(conversationId) {
      return isPlayer()
        && groupConversationParticipant(conversationId)
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'senderUid',
          'text',
          'type',
          'searchTokens',
          'createdAt',
          'ttlExpiresAt'
        ]);
    }

    match /conversations/{conversationId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow update: if signedIn()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants;
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;
      allow delete: if false;
      match /messages/{messageId} {
        allow read: if signedIn() && conversationParticipant(conversationId);
        allow create: if signedIn() && directMessageCreateAllowed(conversationId);
        allow update: if false;
        allow delete: if false;
      }
    }

    match /playerConversations/{conversationId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn() && (
        request.auth.uid in request.resource.data.participants ||
        request.resource.data.keys().hasOnly(['lastSentAtByUid'])
      );
      allow update: if signedIn() && (
        (
          request.auth.uid in resource.data.participants &&
          request.resource.data.participants == resource.data.participants
        ) ||
        (
          !resource.data.keys().hasAny(['participants']) &&
          request.auth.uid in request.resource.data.participants
        )
      );
      allow delete: if false;
      match /messages/{messageId} {
        allow read: if signedIn() && playerConversationParticipant(conversationId);
        allow create: if signedIn() && playerMessageCreateAllowed(conversationId);
        allow update: if signedIn() && playerMessageUpdateAllowed(conversationId);
        allow delete: if false;
      }
    }

    match /playerGroupConversations/{conversationId} {
      allow read: if signedIn() && (
        isAdmin() ||
        (isScopedWorker() && scopedToCaller(resource.data)) ||
        (isPlayer() && groupConversationParticipant(conversationId))
      );
      allow create: if signedIn() && (
        (
          isPlayer() &&
          conversationId == 'global' &&
          request.resource.data.keys().hasOnly([
            'updatedAt',
            'lastMessage',
            'lastMessageAt'
          ])
        ) ||
        (
          isPlayer() &&
          hasParticipant(request.resource.data) &&
          request.resource.data.keys().hasOnly([
            'participants',
            'coadminUid',
            'createdAt',
            'updatedAt',
            'lastMessage',
            'lastMessageAt'
          ])
        )
      );
      allow update: if signedIn() && (
        (
          isPlayer() &&
          conversationId == 'global' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'updatedAt',
            'lastMessage',
            'lastMessageAt'
          ])
        ) ||
        (
          isPlayer() &&
          groupConversationParticipant(conversationId) &&
          request.resource.data.participants == resource.data.participants &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'updatedAt',
            'lastMessage',
            'lastMessageAt'
          ])
        )
      );
      allow delete: if false;
      match /messages/{messageId} {
        allow read: if signedIn() && (
          isAdmin() ||
          (
            isScopedWorker() &&
            exists(/databases/$(database)/documents/playerGroupConversations/$(conversationId)) &&
            scopedToCaller(get(/databases/$(database)/documents/playerGroupConversations/$(conversationId)).data)
          ) ||
          (isPlayer() && groupConversationParticipant(conversationId))
        );
        allow create: if signedIn() && groupMessageCreateAllowed(conversationId);
        allow update, delete: if false;
      }
    }

    match /automation_auto_state/{carerUid} {
      allow read: if signedIn() && request.auth.uid == carerUid;
      allow create, update: if signedIn() && request.auth.uid == carerUid;
      allow delete: if false;
    }

    function automationJobActiveStatus(status) {
      return status in ['queued', 'waiting', 'running', 'in_progress', 'cancelled_requested'];
    }

    function automationJobCreateAllowed() {
      return isCarer()
        && request.resource.data.carerUid == request.auth.uid
        && request.resource.data.createdByUid == request.auth.uid
        && scopedToCaller(request.resource.data)
        && request.resource.data.status == 'queued'
        && request.resource.data.keys().hasOnly([
          'carerUid',
          'coadminUid',
          'agentId',
          'taskId',
          'type',
          'status',
          'payload',
          'createdByUid',
          'createdByName',
          'createdAt',
          'updatedAt',
          'startedAt',
          'completedAt',
          'ttlExpiresAt',
          'error',
          'attempts',
          'lastHeartbeatAt'
        ]);
    }

    function automationJobSafeClientUpdateAllowed() {
      return isCarer()
        && resource.data.carerUid == request.auth.uid
        && request.resource.data.carerUid == resource.data.carerUid
        && request.resource.data.coadminUid == resource.data.coadminUid
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.taskId == resource.data.taskId
        && request.resource.data.type == resource.data.type
        && request.resource.data.agentId == resource.data.agentId
        && request.resource.data.payload == resource.data.payload
        && scopedToCaller(resource.data)
        && automationJobActiveStatus(resource.data.status)
        && request.resource.data.status in ['cancelled', 'failed']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'claimedStatus',
          'cancelledAt',
          'cancelledReason',
          'updatedAt',
          'lastHeartbeatAt',
          'completedAt',
          'ttlExpiresAt',
          'error',
          'result',
          'startedAt'
        ]);
    }

    match /automation_jobs/{jobId} {
      allow read: if signedIn() && (
        isAdmin() ||
        (isCarer() && resource.data.carerUid == request.auth.uid) ||
        (isScopedWorker() && scopedToCaller(resource.data))
      );

      allow create: if signedIn() && (
        isAdmin() ||
        automationJobCreateAllowed()
      );

      allow update: if signedIn() && (
        isAdmin() ||
        automationJobSafeClientUpdateAllowed()
      );

      allow delete: if false;
    }

    match /{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
